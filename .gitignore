# Xcode per-user settings (never commit)
xcuserdata/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate

# macOS
.DS_Store

# Build outputs
DerivedData/
build/

# CocoaPods (Podfile and Podfile.lock are committed; Pods/ is regenerated)
Pods/

# Secrets (API keys, tokens)
SkeenaSystem/Config/Secrets.xcconfig

# Claude Code — commit shared context & commands, keep personal files local
.claude/*
!.claude/CLAUDE.md
!.claude/commands/
!.claude/agents/
!.claude/settings.json
!.claude/list-commands.sh

# Babysitter framework state (logs, journal, run metadata)
.a5c/
babysitter*.log

# UAT test-case artifacts (manually maintained spreadsheets, not source-of-truth)
docs/uat/

